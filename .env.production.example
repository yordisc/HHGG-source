APP_NAME="Instituto de Certificaciones Dudosas"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-servicio.onrender.com

# ─── Localización y formato ──────────────────────────────────────────────────
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=info

# ─── Base de datos externa (elige uno) ───────────────────────────────────────
# 1) URL única del proveedor
DB_CONNECTION=pgsql
DB_URL=
# DATABASE_URL=
DB_SSLMODE=require

# 2) Variables separadas
# DB_HOST=
# DB_PORT=
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

# ─── Cache, sesiones y colas ─────────────────────────────────────────────────
# Producción recomendada: Redis (Upstash u otro servicio administrado)
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync

# Redis
REDIS_CLIENT=phpredis
REDIS_URL=rediss://default:<PASSWORD>@<HOST>:<PORT>
# REDIS_HOST=
# REDIS_PORT=
# REDIS_USERNAME=
# REDIS_PASSWORD=

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Variables del proyecto ──────────────────────────────────────────────────

# Admin: clave para panel admin y webhook scheduler
ADMIN_ACCESS_KEY=

# Admin principal (opcional): usado por scripts/manage-admin.sh sync-env
ADMIN_PRIMARY_NAME=
ADMIN_PRIMARY_EMAIL=
ADMIN_PRIMARY_PASSWORD=

# Scheduler webhook externo:
# POST /api/webhooks/scheduler con header X-Admin-Access-Key: ${ADMIN_ACCESS_KEY}

# Opcionales
LINKEDIN_ORG_ID=
MYMEMORY_EMAIL=
CERTIFICATE_MODE=demo

# Sandbox QA (debe permanecer deshabilitado en producción)
ENABLE_SANDBOX_SEED_DATA=false
# SANDBOX_TEST_PASSWORD=

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
