APP_NAME="Instituto de Certificaciones Dudosas"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://tu-servicio.onrender.com

LOG_CHANNEL=stack
LOG_LEVEL=info

# Base de datos externa (elige uno):
# 1) URL única del proveedor
DB_CONNECTION=pgsql
DB_URL=
# DATABASE_URL=
DB_SSLMODE=require

# 2) Variables separadas
# DB_HOST=
# DB_PORT=
# DB_DATABASE=
# DB_USERNAME=
# DB_PASSWORD=

# Estado efímero en Redis (Upstash)
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=sync
REDIS_CLIENT=phpredis
REDIS_URL=rediss://default:<PASSWORD>@<HOST>:<PORT>

# Webhook scheduler externo
ADMIN_ACCESS_KEY=

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Opcionales
LINKEDIN_ORG_ID=
MYMEMORY_EMAIL=
CERTIFICATE_MODE=demo
