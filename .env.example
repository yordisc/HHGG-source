APP_NAME="Instituto de Certificaciones Dudosas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Localización y formato ──────────────────────────────────────────────────
APP_TIMEZONE=UTC
APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

# ─── Base de Datos ────────────────────────────────────────────────────────────
# Local: MySQL/MariaDB
# Producción (Render / Neon / Aiven): usa DB_CONNECTION=mysql o pgsql y, si
# tu proveedor entrega una URL única, define DB_URL o DATABASE_URL.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=certificados_dev
DB_USERNAME=laravel
DB_PASSWORD=secret
# DB_URL=
# DATABASE_URL=
# DB_SSLMODE=require

# ─── Caché, Sesiones y Colas ─────────────────────────────────────────────────
# Local recomendado: drivers basados en BD
# Produccion recomendada (Render + DB externa): usa Redis
# CACHE_STORE=redis
# SESSION_DRIVER=redis
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# Redis (si habilitas CACHE_STORE/SESSION_DRIVER=redis)
# REDIS_CLIENT=phpredis
# REDIS_URL=redis://default:password@127.0.0.1:6379
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_USERNAME=
# REDIS_PASSWORD=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Mail ────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Variables del proyecto ──────────────────────────────────────────────────

# Admin: clave para el panel y webhook scheduler
ADMIN_ACCESS_KEY=

# Admin principal (opcional): usado por scripts/manage-admin.sh sync-env
ADMIN_PRIMARY_NAME=
ADMIN_PRIMARY_EMAIL=
ADMIN_PRIMARY_PASSWORD=

# Scheduler webhook (externo)
# POST /api/webhooks/scheduler con header X-Admin-Access-Key: ${ADMIN_ACCESS_KEY}

# LinkedIn: ID de página de empresa
# Ejemplo: https://www.linkedin.com/company/12345678 -> LINKEDIN_ORG_ID=12345678
LINKEDIN_ORG_ID=

# MyMemory API: opcional (aumenta límite de traducciones a 10k palabras/día)
MYMEMORY_EMAIL=

# Modo certificado: demo | official
CERTIFICATE_MODE=demo

# Sandbox QA (nunca habilitar en producción)
ENABLE_SANDBOX_SEED_DATA=false
SANDBOX_TEST_PASSWORD=Sandbox123!

# ─── Frontend (Vite) ─────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
