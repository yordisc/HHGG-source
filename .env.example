APP_NAME="Instituto de Certificaciones Dudosas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Base de Datos ────────────────────────────────────────────────────────────
# Codespace/Local: SQLite (sin necesidad de servidor)
# Producción (Railway): Railway inyecta variables de MySQL automáticamente
DB_CONNECTION=sqlite
DB_DATABASE=database/database.sqlite

# ─── Caché, Sesiones y Colas ──────────────────────────────────────────────────
# Drivers basados en BD (sin Redis necesario)
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Variables específicas del proyecto ──────────────────────────────────────

# Admin: clave para entrar al panel oculto /admin
ADMIN_ACCESS_KEY=

# LinkedIn: ID de tu página de empresa en LinkedIn
# Ejemplo: https://www.linkedin.com/company/12345678 → LINKEDIN_ORG_ID=12345678
LINKEDIN_ORG_ID=

# MyMemory API: opcional (aumenta límite de traducciones a 10k palabras/día)
MYMEMORY_EMAIL=

# Modo certificado: demo | official
CERTIFICATE_MODE=demo
CERTIFICATE_MODE=demo

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
