APP_NAME="Instituto de Certificaciones Dudosas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Base de Datos ────────────────────────────────────────────────────────────
# Local (Codespace): usar los valores de abajo
# Producción (Railway): Railway los inyecta automáticamente
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=certificados_dev
DB_USERNAME=laravel
DB_PASSWORD=secret

# ─── Caché, Sesiones y Colas ──────────────────────────────────────────────────
# Usando driver "database" para no necesitar Redis (gratis)
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Mail (no requerido por el proyecto, pero Laravel lo espera) ───────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Variables específicas del proyecto ──────────────────────────────────────

# Admin: clave para entrar al panel oculto /admin
ADMIN_ACCESS_KEY=

# LinkedIn: ID de tu página de empresa en LinkedIn
# Cómo obtenerlo: ir a tu página de empresa en LinkedIn → ver URL → el número al final
# Ejemplo: https://www.linkedin.com/company/12345678 → LINKEDIN_ORG_ID=12345678
LINKEDIN_ORG_ID=

# MyMemory API: opcional, pero aumenta el límite de traducciones de 5.000 a 10.000 palabras/día
# Solo agregar tu email, no requiere registro ni contraseña
MYMEMORY_EMAIL=

# Modo de certificado: demo | official
# - demo: muestra disclaimer de no validez legal en PDF
# - official: oculta ese disclaimer en el PDF oficial
CERTIFICATE_MODE=demo

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
