APP_NAME="Instituto de Certificaciones Dudosas"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# ─── Base de Datos ────────────────────────────────────────────────────────────
# Local: MySQL/MariaDB
# Producción (Render / Neon / Aiven): usa DB_CONNECTION=mysql o pgsql y, si
# tu proveedor entrega una URL única, define DB_URL o DATABASE_URL.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=certificados_dev
DB_USERNAME=laravel
DB_PASSWORD=secret
# DB_URL=
# DATABASE_URL=
# DB_SSLMODE=require

# ─── Caché, Sesiones y Colas ──────────────────────────────────────────────────
# Drivers basados en BD (sin Redis necesario)
CACHE_STORE=database
SESSION_DRIVER=database
SESSION_LIFETIME=120
QUEUE_CONNECTION=database

# ─── Logging ──────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ─── Variables específicas del proyecto ──────────────────────────────────────

# Admin: clave para entrar al panel oculto /admin
ADMIN_ACCESS_KEY=

# LinkedIn: ID de tu página de empresa en LinkedIn
# Ejemplo: https://www.linkedin.com/company/12345678 → LINKEDIN_ORG_ID=12345678
LINKEDIN_ORG_ID=

# MyMemory API: opcional (aumenta límite de traducciones a 10k palabras/día)
MYMEMORY_EMAIL=

# Modo certificado: demo | official
CERTIFICATE_MODE=demo

# ─── Vite ─────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
